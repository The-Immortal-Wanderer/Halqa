# Supabase — get from: Supabase Dashboard → Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://{ref}.supabase.co

# Supabase — get from: Supabase Dashboard → Project Settings → API → anon public key
NEXT_PUBLIC_SUPABASE_ANON_KEY={anon_key}

# FastAPI — use localhost for local dev, api.halqa.pk for production
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1   # development
# NEXT_PUBLIC_API_URL=https://api.halqa.pk/api/v1  # production

# Web Push VAPID — generate via: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY={vapid_public_key}
