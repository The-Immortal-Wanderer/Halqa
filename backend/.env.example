# Supabase — Project URL from: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://{ref}.supabase.co

# Supabase — service_role key from: Supabase Dashboard → Project Settings → API
# WARNING: Keep this secret! Never expose to frontend or client-side code.
SUPABASE_SERVICE_ROLE_KEY={service_role_key}

# Supabase — JWT Secret from: Supabase Dashboard → Project Settings → API → JWT Secret
# Used for validating Supabase-issued JWTs on the server side.
SUPABASE_JWT_SECRET={jwt_secret}

# Anthropic — API key from: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY={api_key}

# Web Push VAPID keys — generate via: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY={vapid_public_key}
VAPID_PRIVATE_KEY={vapid_private_key}
VAPID_EMAIL=mailto:hello@halqa.pk

# Internal service token — generate a random 32-char hex string via: openssl rand -hex 16
# Used for authenticating /internal/* endpoints between backend services.
INTERNAL_SERVICE_TOKEN={random_32_char_token}

# App configuration
ENVIRONMENT=development   # or "production"
LOG_LEVEL=INFO            # DEBUG, INFO, WARNING, ERROR
ALLOWED_ORIGINS=http://localhost:3000  # Comma-separated for multiple origins
